<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_storage_object_tree" model="ir.ui.view">
        <field name="name">custom_storage.object.tree</field>
        <field name="model">custom_storage.object</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'new'" decoration-info="state == 'good'" decoration-warning="state == 'regular'" decoration-danger="state == 'bad'">
                <field name="name"/>
                <field name="location_id"/>
                <field name="quantity" sum="Total"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_storage_object_form" model="ir.ui.view">
        <field name="name">custom_storage.object.form</field>
        <field name="model">custom_storage.object</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="quantity"/>
                            <field name="state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_storage_location_hierarchy" model="ir.ui.view">
        <field name="name">storage.location.hierarchy</field>
        <field name="model">storage.location</field>
        <field name="arch" type="xml">
            <hierarchy child_field="child_ids" draggable="1">
                <field name="name"/>
                <field name="object_count"/>
                <templates>
                    <t t-name="hierarchy-box">
                        <div style="background: white; border: 1px solid #dee2e6; overflow: hidden; min-width: 160px; border-radius: 0px; height: 100%; display: flex; flex-direction: column;">
                            <div style="background-color: #0c273d; padding: 10px; text-align: center;">
                                <i class="fa fa-map-marker" style="color: white; font-size: 20px;"/>
                            </div>
                            <div style="padding: 10px; text-align: center; flex-grow: 1;">
                                <div style="font-weight: bold; color: #212529; font-size: 13px;">
                                    <field name="name"/>
                                </div>
                                <div style="color: #6c757d; font-size: 11px; margin-top: 4px;">
                                    <i class="fa fa-cube"/> <field name="object_count"/> objetos
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </hierarchy>
        </field>
    </record>

    <record id="action_storage_obj_main" model="ir.actions.act_window">
        <field name="name">Mis Objetos</field>
        <field name="res_model">custom_storage.object</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_storage_loc_main" model="ir.actions.act_window">
        <field name="name">Mapa de Almacén</field>
        <field name="res_model">storage.location</field>
        <field name="view_mode">hierarchy,tree,form</field>
    </record>

    <menuitem id="menu_storage_root" name="Almacenamiento" sequence="10"/>
    <menuitem id="menu_storage_objects" name="Objetos" parent="menu_storage_root" action="action_storage_obj_main" sequence="10"/>
    <menuitem id="menu_storage_hierarchy" name="Mapa de Almacén" parent="menu_storage_root" action="action_storage_loc_main" sequence="20"/>
</odoo>